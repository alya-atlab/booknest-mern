{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "moduleResolution": "nodenext",
    "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "moduleDetection": "auto",
    "types": ["node", "jest"],
    
  },
  "include": ["src"]
}